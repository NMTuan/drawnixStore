{
  "name": "drawnixstore-api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/drawnixstore-api/server",
  "projectType": "application",
  "tags": ["scope:drawnixstore"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx nitro build --dir apps/drawnixstore-api"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx nitro dev --dir apps/drawnixstore-api"
      }
    }
  }
}
