# Nitro 服务端运行时变量；生产环境须由部署平台注入，绝不可使用 VITE_ 前缀。
NITRO_POCKETBASE_INTERNAL_URL=http://127.0.0.1:8090
NITRO_POCKETBASE_SUPERUSER_EMAIL=
NITRO_POCKETBASE_SUPERUSER_PASSWORD=
# BFF 写请求允许的固定浏览器来源；生产必须为实际 HTTPS 公开地址。
NITRO_WEB_ORIGIN=http://localhost:7300
# 默认拒绝普通注册；首次初始化由 NITRO_SETUP_TOKEN 授权。
NITRO_REGISTRATION_ENABLED=false
# 使用 openssl rand -hex 32 生成；仅服务端读取，不能使用 VITE_ 前缀。
NITRO_SETUP_TOKEN=
