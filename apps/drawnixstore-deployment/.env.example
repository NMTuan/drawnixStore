# Drawnix Store Compose 部署配置。请将真实值存入未纳入版本控制的 .env；如使用 .env.local，启动时必须传入 --env-file .env.local。
# GitHub Container Registry 基础镜像路径和发布标签；私有包需先执行 docker login ghcr.io。
DRAWNIX_STORE_IMAGE_REPOSITORY=ghcr.io/nmtuan/drawnixstore
# 生产建议使用 GitHub Actions 发布完成后产生的 sha-<短提交> 不可变标签；latest 仅适合测试。
DRAWNIX_STORE_IMAGE_TAG=sha-replace-with-published-commit
# 此地址必须与浏览器实际访问的完整协议、主机和端口一致。
DRAWNIX_STORE_PUBLIC_ORIGIN=https://drawnixstore.example.com
# 仅 v0.2.0 镜像使用此项控制会话 Cookie 的 Secure 属性：HTTPS 必须为 true；
# 受控 HTTP 调试必须显式设为 false，否则浏览器会拒绝 Cookie，登录后访问 /api/workspaces 将返回 401。
# 后续镜像会根据 DRAWNIX_STORE_PUBLIC_ORIGIN 自动判断，不需要设置此项。
# NITRO_SESSION_SECURE=true
# 私有部署默认不开放普通注册。仅多用户自助注册场景才设置为 true。
DRAWNIX_STORE_REGISTRATION_ENABLED=false
# 注册关闭时，首次访问会进入初始化页。必须替换为 openssl rand -hex 32 生成的随机值；
# 创建首账号后该令牌立即失效，但仍应妥善保管，不能提交到版本库；留空会禁用初始化入口。
DRAWNIX_STORE_SETUP_TOKEN=
NITRO_POCKETBASE_SUPERUSER_EMAIL=admin@example.com
NITRO_POCKETBASE_SUPERUSER_PASSWORD=replace-with-a-secret
# 必须替换为安全随机的 32 字节值；此示例仅满足 PocketBase AES 长度要求。
POCKETBASE_ENCRYPTION=0123456789abcdef0123456789abcdef
DRAWNIX_STORE_WEB_BIND=0.0.0.0
DRAWNIX_STORE_WEB_PORT=7300
