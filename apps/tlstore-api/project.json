{
  "name": "tlstore-api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/tlstore-api/server",
  "projectType": "application",
  "tags": ["scope:tlstore"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx nitro build --dir apps/tlstore-api"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx nitro dev --dir apps/tlstore-api"
      }
    }
  }
}
