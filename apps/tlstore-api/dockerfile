# tlStore Nitro API 运行镜像：构建产物必须由宿主机的 build:tlstore-images 预先生成。

# 一次性 Schema 初始化任务只安装生产依赖与原生 ESM 脚本，不进入长期运行的 API 镜像。
FROM node:20-alpine AS bootstrap

WORKDIR /app
COPY apps/tlstore-bootstrap/package.json apps/tlstore-bootstrap/package-lock.json ./
RUN npm ci --omit=dev
COPY scripts/bootstrap-tlstore-pocketbase.mjs ./bootstrap.mjs

CMD ["node", "bootstrap.mjs"]

FROM node:20-alpine AS runtime

WORKDIR /app
ENV NODE_ENV=production
ENV NITRO_PORT=7400
COPY dist/apps/tlstore-api ./

EXPOSE 7400
CMD ["node", "server/index.mjs"]
