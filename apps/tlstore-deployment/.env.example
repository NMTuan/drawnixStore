# tlStore Compose 部署配置。请将真实值存入未纳入版本控制的 .env.local。
TLSTORE_PUBLIC_ORIGIN=https://tlstore.example.com
NITRO_SESSION_SECURE=true
NITRO_POCKETBASE_SUPERUSER_EMAIL=admin@example.com
NITRO_POCKETBASE_SUPERUSER_PASSWORD=replace-with-a-secret
# 必须替换为安全随机的 32 字节值；此示例仅满足 PocketBase AES 长度要求。
POCKETBASE_ENCRYPTION=0123456789abcdef0123456789abcdef
TLSTORE_WEB_BIND=0.0.0.0
TLSTORE_WEB_PORT=7300
