# tlStore 浏览器应用镜像：Nginx 负责 SPA 回退，并将公开 SVG 请求转发给 Nitro。
FROM node:20 AS builder

WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY . .

ARG VITE_POCKETBASE_URL
ARG VITE_TLSTORE_API_URL
ENV VITE_POCKETBASE_URL=$VITE_POCKETBASE_URL
ENV VITE_TLSTORE_API_URL=$VITE_TLSTORE_API_URL
RUN npx nx build tlstore-web

FROM nginx:1.27-alpine

COPY apps/tlstore-web/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist/apps/tlstore-web /usr/share/nginx/html

EXPOSE 80
